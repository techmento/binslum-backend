// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  ADMIN
  ACCOUNTANT
  MANAGER
}

enum ShipStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum IncomeType {
  SALES
  DELIVERY_ORDER
}

enum ExpenseCategory {
  MARINE_BILLS
  SALARY
  MAINTENANCE_REPAIR
  FUEL_COST
  FOOD_GROCERY
  PORT_CASH
  ZMA_BILLS
  LOAN_REPAYMENT
  ADMINISTRATION_COST
  OTHER_COST
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
}

// Models
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  role      UserRole @default(ACCOUNTANT)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  incomeRecords  IncomeRecord[]
  expenseRecords ExpenseRecord[]
  loans          Loan[]
  loanPayments   LoanPayment[]
  payrolls       Payroll[]

  @@map("users")
}

model Ship {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String   @db.VarChar(150)
  registrationNumber   String   @unique @db.VarChar(100) @map("registration_number")
  status               ShipStatus @default(ACTIVE)
  description          String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  employees      Employee[]
  incomeRecords  IncomeRecord[]
  expenseRecords ExpenseRecord[]

  @@map("ships")
}

model Employee {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipId     String   @map("ship_id") @db.Uuid
  name       String   @db.VarChar(150)
  role       String   @db.VarChar(100)
  baseSalary Decimal  @map("base_salary") @db.Decimal(12, 2)
  allowances Decimal  @default(0) @db.Decimal(12, 2)
  deductions Decimal  @default(0) @db.Decimal(12, 2)
  taxRate    Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  ship           Ship           @relation(fields: [shipId], references: [id])
  expenseRecords ExpenseRecord[]
  payrollEntries PayrollEntry[]

  @@index([shipId])
  @@map("employees")
}

model IncomeRecord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipId    String   @map("ship_id") @db.Uuid
  type      IncomeType
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime @db.Date
  description String? @db.Text
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ship Ship @relation(fields: [shipId], references: [id])
  creator User @relation(fields: [createdBy], references: [id])

  @@index([shipId])
  @@index([shipId, date])
  @@map("income_records")
}

model ExpenseRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipId       String   @map("ship_id") @db.Uuid
  category     ExpenseCategory
  amount       Decimal  @db.Decimal(14, 2)
  date         DateTime @db.Date
  paymentMethod PaymentMethod @map("payment_method")
  description  String?  @db.Text
  receiptUrl   String?  @db.VarChar(500) @map("receipt_url")
  employeeId   String?  @map("employee_id") @db.Uuid
  loanPaymentId String? @map("loan_payment_id") @db.Uuid
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  ship        Ship        @relation(fields: [shipId], references: [id])
  employee    Employee?   @relation(fields: [employeeId], references: [id])
  loanPayment LoanPayment? @relation(fields: [loanPaymentId], references: [id])
  creator     User        @relation(fields: [createdBy], references: [id])

  @@index([shipId])
  @@index([shipId, category])
  @@index([shipId, date])
  @@map("expense_records")
}

model Loan {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankName       String   @db.VarChar(200) @map("bank_name")
  totalAmount    Decimal  @db.Decimal(16, 2) @map("total_amount")
  monthlyPayment Decimal  @db.Decimal(14, 2) @map("monthly_payment")
  remainingBalance Decimal @db.Decimal(16, 2) @map("remaining_balance")
  startDate      DateTime @db.Date @map("start_date")
  status         LoanStatus @default(ACTIVE)
  description    String?  @db.Text
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  payments LoanPayment[] @relation("payments")
  creator User @relation(fields: [createdBy], references: [id])

  @@map("loans")
}

model LoanPayment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId     String   @map("loan_id") @db.Uuid
  amountPaid Decimal  @db.Decimal(14, 2) @map("amount_paid")
  paymentDate DateTime @db.Date @map("payment_date")
  notes      String?  @db.Text
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  loan   Loan           @relation("payments", fields: [loanId], references: [id])
  creator User          @relation(fields: [createdBy], references: [id])
  expenseRecords ExpenseRecord[]

  @@index([loanId])
  @@map("loan_payments")
}

model Payroll {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  totalGross  Decimal  @map("total_gross") @db.Decimal(16, 2)
  totalDeductions Decimal @map("total_deductions") @db.Decimal(16, 2)
  totalNet    Decimal  @map("total_net") @db.Decimal(16, 2)
  status      String   @default("DRAFT") // DRAFT, PROCESSED, PAID
  notes       String?  @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  entries PayrollEntry[]
  creator User @relation(fields: [createdBy], references: [id])

  @@map("payrolls")
}

model PayrollEntry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollId  String   @map("payroll_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  baseSalary Decimal  @map("base_salary") @db.Decimal(12, 2)
  allowances Decimal  @db.Decimal(12, 2)
  deductions Decimal  @db.Decimal(12, 2)
  taxAmount  Decimal  @map("tax_amount") @db.Decimal(12, 2)
  grossPay   Decimal  @map("gross_pay") @db.Decimal(12, 2)
  netPay     Decimal  @map("net_pay") @db.Decimal(12, 2)
  status     String   @default("PENDING") // PENDING, PAID
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  payroll  Payroll  @relation(fields: [payrollId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([payrollId])
  @@index([employeeId])
  @@map("payroll_entries")
}
