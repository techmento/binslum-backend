// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  ADMIN
  ACCOUNTANT
  MANAGER
  VIEWER
}

enum ShipStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum IncomeType {
  SALES
  DELIVERY_ORDER
}



enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
}

enum SalaryPaymentType {
  FULL
  PARTIAL
  BONUS
}

// Models
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  role      UserRole @default(ACCOUNTANT)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  incomeRecords          IncomeRecord[]
  expenseRecords         ExpenseRecord[]
  loans                  Loan[]
  loanPayments           LoanPayment[]
  payrolls               Payroll[]
  customExpenseCategories CustomExpenseCategory[]
  salaryRecords          SalaryRecord[]
  salaryPayments         SalaryPayment[]
  salaryBonuses          SalaryBonus[]
  salaryDeductions       SalaryDeduction[]
  employeeDocuments      EmployeeDocument[]

  @@map("users")
}

model Ship {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String   @db.VarChar(150)
  registrationNumber   String   @unique @db.VarChar(100) @map("registration_number")
  status               ShipStatus @default(ACTIVE)
  description          String?  @db.Text
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  employees      Employee[]
  incomeRecords  IncomeRecord[]
  expenseRecords ExpenseRecord[]

  @@map("ships")
}

model Employee {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipId     String?  @map("ship_id") @db.Uuid
  name       String   @db.VarChar(150)
  role       String   @db.VarChar(100)
  phone      String?  @db.VarChar(30)
  baseSalary Decimal  @map("base_salary") @db.Decimal(12, 2)
  allowances Decimal  @default(0) @db.Decimal(12, 2)
  deductions Decimal  @default(0) @db.Decimal(12, 2)
  taxRate    Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  ship           Ship?              @relation(fields: [shipId], references: [id])
  expenseRecords ExpenseRecord[]
  payrollEntries PayrollEntry[]
  salaryRecords  SalaryRecord[]
  documents      EmployeeDocument[]

  @@index([shipId])
  @@map("employees")
}

model EmployeeDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  name         String   @db.VarChar(200)
  fileUrl      String   @map("file_url") @db.VarChar(500)
  fileType     String?  @map("file_type") @db.VarChar(50)
  fileSize     Int?     @map("file_size")
  uploadedBy   String   @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploadedBy], references: [id])

  @@index([employeeId])
  @@map("employee_documents")
}

model IncomeRecord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipId    String   @map("ship_id") @db.Uuid
  type      IncomeType
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime @db.Date
  description String? @db.Text
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ship Ship @relation(fields: [shipId], references: [id])
  creator User @relation(fields: [createdBy], references: [id])

  @@index([shipId])
  @@index([shipId, date])
  @@map("income_records")
}

model ExpenseRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipId       String?  @map("ship_id") @db.Uuid
  category     String @db.VarChar(100)
  amount       Decimal  @db.Decimal(14, 2)
  date         DateTime @db.Date
  paymentMethod PaymentMethod @map("payment_method")
  description  String?  @db.Text
  receiptUrl   String?  @db.VarChar(500) @map("receipt_url")
  employeeId   String?  @map("employee_id") @db.Uuid
  loanPaymentId String? @map("loan_payment_id") @db.Uuid
  salaryPaymentType SalaryPaymentType? @map("salary_payment_type")
  salaryMonth  DateTime? @db.Date @map("salary_month")
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  ship        Ship?       @relation(fields: [shipId], references: [id])
  employee    Employee?   @relation(fields: [employeeId], references: [id])
  loanPayment LoanPayment? @relation(fields: [loanPaymentId], references: [id])
  creator     User        @relation(fields: [createdBy], references: [id])

  @@index([shipId])
  @@index([shipId, category])
  @@index([shipId, date])
  @@index([employeeId, salaryMonth])
  @@map("expense_records")
}

model Loan {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankName       String   @db.VarChar(200) @map("bank_name")
  totalAmount    Decimal  @db.Decimal(16, 2) @map("total_amount")
  monthlyPayment Decimal  @db.Decimal(14, 2) @map("monthly_payment")
  remainingBalance Decimal @db.Decimal(16, 2) @map("remaining_balance")
  startDate      DateTime @db.Date @map("start_date")
  status         LoanStatus @default(ACTIVE)
  description    String?  @db.Text
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  payments LoanPayment[] @relation("payments")
  creator User @relation(fields: [createdBy], references: [id])

  @@map("loans")
}

model LoanPayment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loanId     String   @map("loan_id") @db.Uuid
  amountPaid Decimal  @db.Decimal(14, 2) @map("amount_paid")
  paymentDate DateTime @db.Date @map("payment_date")
  notes      String?  @db.Text
  createdBy  String   @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  loan   Loan           @relation("payments", fields: [loanId], references: [id])
  creator User          @relation(fields: [createdBy], references: [id])
  expenseRecords ExpenseRecord[]

  @@index([loanId])
  @@map("loan_payments")
}

model Payroll {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  totalGross  Decimal  @map("total_gross") @db.Decimal(16, 2)
  totalDeductions Decimal @map("total_deductions") @db.Decimal(16, 2)
  totalNet    Decimal  @map("total_net") @db.Decimal(16, 2)
  status      String   @default("DRAFT") // DRAFT, PROCESSED, PAID
  notes       String?  @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  entries PayrollEntry[]
  creator User @relation(fields: [createdBy], references: [id])

  @@map("payrolls")
}

model PayrollEntry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollId  String   @map("payroll_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  baseSalary Decimal  @map("base_salary") @db.Decimal(12, 2)
  allowances Decimal  @db.Decimal(12, 2)
  deductions Decimal  @db.Decimal(12, 2)
  taxAmount  Decimal  @map("tax_amount") @db.Decimal(12, 2)
  grossPay   Decimal  @map("gross_pay") @db.Decimal(12, 2)
  netPay     Decimal  @map("net_pay") @db.Decimal(12, 2)
  status     String   @default("PENDING") // PENDING, PAID
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  payroll  Payroll  @relation(fields: [payrollId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([payrollId])
  @@index([employeeId])
  @@map("payroll_entries")
}

enum SalaryStatus {
  UNPAID
  PARTIAL
  PAID
}

enum DeductionReason {
  LOAN
  SALARY_ADVANCE
  TAX_ADJUSTMENT
  ABSENCE
  LATE_ATTENDANCE
  PROPERTY_DAMAGE
  OTHER
}

model SalaryRecord {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId      String       @map("employee_id") @db.Uuid
  salaryYear      Int          @map("salary_year")
  salaryMonth     Int          @map("salary_month")
  grossSalary     Decimal      @map("gross_salary") @db.Decimal(14, 2)
  totalDeductions Decimal      @default(0) @map("total_deductions") @db.Decimal(14, 2)
  netSalary       Decimal      @map("net_salary") @db.Decimal(14, 2)
  amountPaid      Decimal      @default(0) @map("amount_paid") @db.Decimal(14, 2)
  status          SalaryStatus @default(UNPAID)
  notes           String?      @db.Text
  createdBy       String       @map("created_by") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  employee   Employee         @relation(fields: [employeeId], references: [id])
  creator    User             @relation(fields: [createdBy], references: [id])
  payments   SalaryPayment[]
  bonuses    SalaryBonus[]
  deductions SalaryDeduction[]

  @@unique([employeeId, salaryYear, salaryMonth])
  @@index([employeeId])
  @@index([salaryYear, salaryMonth])
  @@index([status])
  @@map("salary_records")
}

model SalaryPayment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salaryRecordId String   @map("salary_record_id") @db.Uuid
  amount         Decimal  @db.Decimal(14, 2)
  paymentDate    DateTime @map("payment_date") @db.Date
  paymentMethod  PaymentMethod @map("payment_method")
  receiptUrl     String?  @map("receipt_url") @db.VarChar(500)
  notes          String?  @db.Text
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  salaryRecord SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id])

  @@index([salaryRecordId])
  @@map("salary_payments")
}

model SalaryBonus {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salaryRecordId String   @map("salary_record_id") @db.Uuid
  amount         Decimal  @db.Decimal(14, 2)
  reason         String   @db.VarChar(300)
  bonusDate      DateTime @map("bonus_date") @db.Date
  paymentMethod  PaymentMethod @map("payment_method")
  receiptUrl     String?  @map("receipt_url") @db.VarChar(500)
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  salaryRecord SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id])

  @@index([salaryRecordId])
  @@map("salary_bonuses")
}

model SalaryDeduction {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salaryRecordId String          @map("salary_record_id") @db.Uuid
  amount         Decimal         @db.Decimal(14, 2)
  reason         DeductionReason
  notes          String?         @db.Text
  deductionDate  DateTime        @map("deduction_date") @db.Date
  createdBy      String          @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")

  salaryRecord SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id])

  @@index([salaryRecordId])
  @@map("salary_deductions")
}

model CustomExpenseCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(100)
  label     String   @db.VarChar(150)
  color     String   @default("#7C3AED") @db.VarChar(20)
  fade      String   @default("#F5F3FF") @db.VarChar(20)
  border    String   @default("#DDD6FE") @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  creator User @relation(fields: [createdBy], references: [id])

  @@map("custom_expense_categories")
}
